# Copy this file to .env and fill in your own values:
#   cp .env.example .env
# .env is gitignored — never commit a real key. The app loads .env automatically
# (via python-dotenv) when you run `streamlit run app.py` or `python build.py`.

# FRED API key — free and instant: https://fredaccount.stlouisfed.org/apikeys
# Optional. Without it the dashboard still runs on BLS QCEW data; only the
# Real GDP and unemployment-rate KPI cells degrade to "—".
FRED_API_KEY=your_fred_api_key_here
