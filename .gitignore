__pycache__/
*.pyc
*.bak
.venv/
venv/
.env
.claude/
*.egg-info/
dist/
build/
.DS_Store
# Ignore the large/derived caches, but commit the small FRED parquets so CI has
# a last-good fallback when a fresh FRED fetch fails (see data/fetch_fred.py).
data/cache/*
!data/cache/qcew_fred_gdp.parquet
!data/cache/qcew_fred_unrate.parquet
scratch/
